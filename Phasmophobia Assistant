#include <iostream>
#include <vector>
#include <string>
#include <algorithm>

using namespace std;

enum evidence 
{
    EMF5,
    SPIRIT_BOX,
    UV,
    GHOST_ORB,
    GHOST_WRITING,
    FREEZING_TEMPS,
    DOTS,
    NONE
};


string evidenceToString(evidence e) 
{
    switch (e) 
    {
    case EMF5: return "EMF Level 5";
    case SPIRIT_BOX: return "Spirit Box";
    case UV: return "UV";
    case GHOST_ORB: return "Ghost Orb";
    case GHOST_WRITING: return "Ghost Writing";
    case FREEZING_TEMPS: return "Freezing Temps";
    case DOTS: return "D.O.T.S Projector";
    default: return "None";
    }
}

class ghost 
{
public:
    string name;
    vector<evidence> evidences;
    string definitiveTell;

    ghost(string n, vector<evidence> e, string d) 
    {
        name = n;
        evidences = e;
        definitiveTell = d;
    }

    void display() 
    {
        cout << "\nGhost: " << name << endl;
        cout << "Evidence: ";
        for (auto e : evidences) {
            cout << evidenceToString(e) << ", ";
        }
        cout << "\nDescription: " << definitiveTell << endl;
    }
};

class phasAssistant 
{
private:
    vector<ghost> ghosts;
    vector<evidence> collectedEvidence;

public:
    phasAssistant() 
    {
        initializeGhosts();
    }

    void initializeGhosts() 
    {
        ghosts.push_back(ghost("Banshee", {UV, GHOST_ORB, DOTS}, "A Banshee priortizes one player over everyone else and can only be a female model. Additonally, a Banshee's scream is unique and can be picked up on a parabolic microphone."));
